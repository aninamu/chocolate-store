# Project-local MongoDB and Redis (see scripts/services-up.sh)
MONGO_PORT=27017
MONGO_DB=chocolate_store
REDIS_PORT=63790
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend — Mongo is the primary store after cutover
MONGODB_ENABLED=true
MONGODB_URL=mongodb://127.0.0.1:27017/chocolate_store
DB_READ_SOURCE_CHOCOLATES=mongo
DB_WRITE_MODE_ORDERS=mongo
DUAL_WRITE_STRICT=true
DUAL_WRITE_ORDERS_PRIMARY=postgres

REDIS_URL=redis://127.0.0.1:63790/0
CACHE_TTL_SECONDS=60

# Optional Postgres for cutover (dual-write / backfill / reconcile).
# Set ENABLE_POSTGRES=1 in the shell (or uncomment below) when using cutover tooling.
# PG_PORT=55432
# PG_USER=chocolate
# PG_DB=chocolate_store
# DATABASE_URL=postgresql+asyncpg://chocolate@127.0.0.1:55432/chocolate_store
# ENABLE_POSTGRES=1
# PERSIST_DATA=0

# Frontend (browser fetches the API; must match where uvicorn runs)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Dev mode: Cloud agent via @cursor/sdk (Next.js server only — never expose to the browser)
# Get a key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# Optional: HTTPS GitHub repo URL (must be connected in Cursor). If unset, `git remote get-url origin` from the repo root is used when available.
# CURSOR_DEV_MODE_REPO_URL=https://github.com/your-org/your-repo
# Optional branch or tag for the cloud clone (default: main)
# CURSOR_DEV_MODE_STARTING_REF=main
