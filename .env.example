# Project-local PostgreSQL and Redis (see scripts/services-up.sh)
PG_PORT=55432
PG_USER=chocolate
PG_DB=chocolate_store
REDIS_PORT=63790
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend (sqlx async; DATABASE_URL may use postgresql+asyncpg:// — normalized at runtime)
DATABASE_URL=postgresql+asyncpg://chocolate@127.0.0.1:55432/chocolate_store
REDIS_URL=redis://127.0.0.1:63790/0
CACHE_TTL_SECONDS=60

# Frontend (browser fetches the API; must match where the Axum server runs)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Dev mode: Cloud agent via @cursor/sdk (Next.js server only — never expose to the browser)
# Get a key from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# Optional: HTTPS GitHub repo URL (must be connected in Cursor). If unset, `git remote get-url origin` from the repo root is used when available.
# CURSOR_DEV_MODE_REPO_URL=https://github.com/your-org/your-repo
# Optional branch or tag for the cloud clone (default: main)
# CURSOR_DEV_MODE_STARTING_REF=main
