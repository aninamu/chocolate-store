# Project-local PostgreSQL and Redis (see scripts/services-up.sh)
PG_PORT=55432
PG_USER=chocolate
PG_DB=chocolate_store
REDIS_PORT=63790
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend (SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://chocolate@127.0.0.1:55432/chocolate_store
REDIS_URL=redis://127.0.0.1:63790/0
CACHE_TTL_SECONDS=60

# Frontend (browser fetches the API; must match where uvicorn runs)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
